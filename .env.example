# Clerk authentication keys (from Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook signing secret (Svix)
SIGNING_SECRET=

# MongoDB connection string
MONGODB_URI=

# Optional: Resend API key for the contact/email feature
RESEND_API_KEY=

# Public site URL (set to your Vercel deployment URL in production)
URL=http://localhost:3000
